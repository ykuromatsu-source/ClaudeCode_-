# Instagram Graph API (Meta Graph API) 設定テンプレート。
#
# 使い方:
#   1. このファイルを `.env` としてコピーする（`.env` は .gitignore で除外済み・
#      Gitにコミットされないため、実際のトークンを安全に置ける）。
#        cp .env.example .env
#   2. 下記の値を実際の認証情報で埋める。
#
# INSTAGRAM_ACCESS_TOKEN が未設定、または scripts/sns_orchestrator.py の
# --dry-run フラグ指定時は、実際のHTTPリクエストを送信せず安全なモック
# モード（送信予定のペイロードをログ出力するのみ）で動作する。

# InstagramビジネスアカウントのユーザーID（Meta Graph APIのIG User ID）
INSTAGRAM_ACCOUNT_ID=

# Instagramビジネスアカウントに対する長期アクセストークン
# （Meta for Developers > アプリ > Instagram Graph API から発行）
INSTAGRAM_ACCESS_TOKEN=

# 使用するMeta Graph APIのバージョン（既定: v20.0）
META_GRAPH_API_VERSION=v20.0
